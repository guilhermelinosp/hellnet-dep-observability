# Hellnet Observability - Environment Variables Configuration
# Copy this file to .env and fill in the required values for your deployment

# ============================================================================
# REQUIRED ENVIRONMENT VARIABLES (Must be set)
# ============================================================================

# Service name identifier - must be unique per microservice
# Examples: "order-service", "payment-api", "user-service"
HELLNET_SERVICE_NAME=my-microservice

# OpenTelemetry Protocol (OTLP) collector endpoint
# This should point to your Grafana Alloy, Jaeger, or OpenTelemetry Collector
# Examples:
#   - http://localhost:4317 (local development)
#   - http://otel-collector.default.svc.cluster.local:4317 (Kubernetes)
#   - https://otel-collector.example.com (remote)
HELLNET_OTLP_ENDPOINT=http://localhost:4317


# ============================================================================
# OPTIONAL ENVIRONMENT VARIABLES (Have defaults)
# ============================================================================

# OTLP Protocol - gRPC (default) or HTTP
# - grpc: Better performance, requires gRPC support (default)
# - http: More compatible, uses more bandwidth
HELLNET_OTLP_PROTOCOL=grpc

# .NET environment (standard host variable)
DOTNET_ENVIRONMENT=Development
